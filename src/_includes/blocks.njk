{%- if pg.head.photo %}
{%- set hd = pg.head.photo | imgDims %}
<section class="pagehead pagehead-split"><div class="wrap reveal">
  <div class="ph-grid">
    <div class="ph-text">
      <div class="kick">{{ pg.head.kick | safe }}</div><h1>{{ pg.head.title | safe }}</h1>
      <p>{{ pg.head.intro | safe }}</p>
    </div>
    <div class="ph-photo">
      <img src="{{ pg.head.photo }}" alt="{{ pg.head.photo_alt }}"{% if hd %} width="{{ hd.w }}" height="{{ hd.h }}"{% endif %} />
      {%- if pg.head.photo_caption %}<div class="cap-inline">{{ pg.head.photo_caption | safe }}</div>{% endif %}
    </div>
  </div>
</div></section>
{%- else %}
<section class="pagehead"><div class="wrap reveal">
  <div class="kick">{{ pg.head.kick | safe }}</div><h1>{{ pg.head.title | safe }}</h1>
  <p>{{ pg.head.intro | safe }}</p>
</div></section>
{%- endif %}
{%- for b in pg.sections %}
{%- if b.type == "band" %}
<div class="band{% if b.tall %} band-tall{% endif %} reveal"><img src="{{ b.image | replace("XNONEX", "XNONEX") }}" alt="{{ b.alt }}"{% if b.position %} style="object-position:{{ b.position }}"{% endif %}  loading="lazy" />
{%- if b.quote %}
  <div class="wrap"><div class="cap"><div class="q">{{ b.quote | safe }}</div><div class="src">{{ b.source | safe }}</div></div></div>
{%- endif %}
</div>
{%- elif b.type == "text" %}
<section class="paper sec"><div class="wrap">
  {%- if b.label %}
  <div class="movement reveal"><span class="lbl">{{ b.label | safe }}</span><span class="rule"></span></div>
  {%- endif %}
  <div class="bodytext reveal">
    {%- for p in b.paragraphs %}
    <p>{{ p.text | safe }}</p>
    {%- endfor %}
  </div>
</div></section>
{%- elif b.type == "text_photo" %}
<section class="paper sec"><div class="wrap">
  <div class="two">
    {%- if b.image_side == "left" %}
    <figure class="portrait-card reveal" style="margin:0"><img src="{{ b.image | replace("XNONEX", "XNONEX") }}" alt="{{ b.alt }}"  loading="lazy" /></figure>
    {%- endif %}
    <div class="bodytext reveal">
      {%- for p in b.paragraphs %}
      <p>{{ p.text | safe }}</p>
      {%- endfor %}
      {%- if b.offers and b.offers.length %}
      <div class="offer" style="grid-template-columns:1fr;margin-top:30px">
        {%- for o in b.offers %}
        <div class="o"><h4>{{ o.heading | safe }}</h4><p>{{ o.text | safe }}</p></div>
        {%- endfor %}
      </div>
      {%- endif %}
      {%- if b.cta_label %}
      <div class="cta-row reveal"><a class="btn btn-gilt" href="{{ b.cta_link }}">{{ b.cta_label | safe }}</a></div>
      {%- endif %}
    </div>
    {%- if b.image_side != "left" %}
    <figure class="portrait-card reveal" style="margin:0"><img src="{{ b.image | replace("XNONEX", "XNONEX") }}" alt="{{ b.alt }}"  loading="lazy" /></figure>
    {%- endif %}
  </div>
</div></section>
{%- elif b.type == "text_appointments" %}
<section class="paper sec"><div class="wrap">
  <div class="two">
    <div class="bodytext reveal">
      {%- for p in b.paragraphs %}
      <p>{{ p.text | safe }}</p>
      {%- endfor %}
    </div>
    <div class="reveal">{% for po in b.posts %}<div class="post"><div><div class="p-role">{{ po.role | safe }}</div><div class="p-place">{{ po.place | safe }}</div></div><div class="p-loc">{{ po.location | safe }}</div></div>{% endfor %}</div>
  </div>
</div></section>
{%- elif b.type == "text_studio" %}
<section class="paper sec"><div class="wrap">
  <div class="two">
    <div class="bodytext reveal">
      {%- for p in b.paragraphs %}
      <p>{{ p.text | safe }}</p>
      {%- endfor %}
      {%- if b.photo %}
      {%- set sd = b.photo | imgDims %}
      <figure class="portrait-card studio-photo reveal" style="margin:30px 0 0"><img src="{{ b.photo }}" alt="{{ b.photo_alt }}"{% if sd %} width="{{ sd.w }}" height="{{ sd.h }}"{% endif %} loading="lazy" />{% if b.photo_caption %}<div class="cap">{{ b.photo_caption | safe }}</div>{% endif %}</figure>
      {%- endif %}
    </div>
    <div class="studio reveal">
      <div class="movement" style="margin-bottom:14px"><span class="lbl">{{ b.studio_label | safe }}</span></div>
      <h3>{{ b.studio_heading | safe }}</h3>
      <p>{{ b.studio_text | safe }}</p>
      <div class="instr-grid">{% for i in b.instruments %}<div class="instr-card"><img src="{{ i.icon | replace("XNONEX", "XNONEX") }}" alt="{{ i.label }}"  loading="lazy" /><span>{{ i.label | safe }}</span></div>{% endfor %}</div>
      <a class="btn btn-gilt" href="{{ b.cta_link }}">{{ b.cta_label | safe }}</a>
    </div>
  </div>
</div></section>
{%- elif b.type == "scholarship" %}
<section class="diss"><div class="wrap">
  <div class="euch reveal">
    <img class="euch-monstrance" src="/assets/img/monstrance.svg" alt="" aria-hidden="true"  loading="lazy" />
    <blockquote class="euch-q">{{ b.latin | safe }}<span>{{ b.translation | safe }}</span></blockquote>
    <p class="euch-sub">{{ b.text | safe }}</p>
  </div>
  <div class="diss-card reveal">
  <div class="movement center"><span class="lbl">{{ b.label | safe }}</span></div>
  <div class="deg">{{ b.degree | safe }}</div>
  <h2>{{ b.title | safe }}</h2>
  <p class="sub">{{ b.subtitle | safe }}</p>
  <div class="meta">{% for m in b.meta %}<span>{{ m.role | safe }} &nbsp;<b>{{ m.name | safe }}</b></span>{% endfor %}</div>
</div></div></section>
{%- elif b.type == "patrons" %}
<section class="patron-sec reveal"><div class="wrap">
  <img class="patron-orn" src="/assets/img/rose-mark.svg" alt="" aria-hidden="true"  loading="lazy" />
  <div class="patron-label">{{ b.label | safe }}</div>
  <div class="patrons">
    {%- for p in b.patrons %}
    <div class="patron">
      <figure class="patron-fig"><img src="{{ p.image | replace("XNONEX", "XNONEX") }}" alt="{{ p.alt }}"  loading="lazy" /></figure>
      <div class="patron-name">{{ p.name | safe }}</div>
      <div class="patron-desc">{{ p.description | safe }}</div>
      <blockquote class="patron-q">{{ p.latin | safe }}<span>{{ p.translation | safe }}</span></blockquote>
    </div>
    {%- endfor %}
  </div>
</div></section>
{%- elif b.type == "stage_work" %}
<section class="paper sec"><div class="wrap">
  <div class="movement reveal"><span class="lbl">{{ b.label | safe }}</span><span class="rule"></span></div>
  <div class="two">
    <div class="reveal"><table class="program">{% for r in b.roles %}<tr><td class="role">{{ r.role | safe }}</td><td class="work">{{ r.work | safe }}</td><td class="co">{{ r.company | safe }}</td></tr>{% endfor %}</table>
      <div class="scenes"><b>{{ b.scenes_heading | safe }}</b>{{ b.scenes_text | safe }}</div>
    </div>
    <div class="perf-stack reveal">{% for f in b.photos %}<figure class="figcap" style="margin:0"><img src="{{ f.image | replace("XNONEX", "XNONEX") }}" alt="{{ f.alt }}"  loading="lazy" /><figcaption>{{ f.caption | safe }}</figcaption></figure>{% endfor %}</div>
  </div>
  <div class="listcols reveal">
    {%- for col in b.columns %}
    <div><h3>{{ col.heading | safe }}</h3>
      {%- for e in col.entries %}
      <div class="cs-entry">{% if e.tag %}<span class="tag">{{ e.tag | safe }}</span>{% endif %}<div class="t">{{ e.title | safe }}</div><div class="d">{{ e.detail | safe }}</div></div>
      {%- endfor %}
      {%- if col.photo %}<figure class="recital-fig reveal"><img src="{{ col.photo | replace("XNONEX", "XNONEX") }}" alt="{{ col.photo_alt }}"  loading="lazy" /></figure>{% endif %}
    </div>
    {%- endfor %}
  </div>
</div></section>
{%- elif b.type == "recordings" %}
<section class="recordings sec" style="background:var(--ink-2);border-top:1px solid var(--rule-d)"><div class="wrap">
  <div class="movement reveal"><span class="lbl">{{ b.label | safe }}</span><span class="rule"></span></div>
  <p class="rec-intro reveal">{{ b.intro | safe }}</p>
  <div class="rel-list">
    {%- for r in b.releases %}
    <article class="rel-card reveal">
      <img class="rel-cover" src="{{ r.cover | replace("XNONEX", "XNONEX") }}" alt="{{ r.cover_alt }}" loading="lazy" />
      <div class="rel-body">
        <div class="rel-tag">{{ r.tag | safe }}</div>
        <h3 class="rel-title">{{ r.title | safe }}</h3>
        <div class="rel-credit">{{ r.credit | safe }}</div>
        <div class="rel-role">{{ r.role | safe }}</div>
        <div class="rel-note">{{ r.note | safe }}</div>
        <div class="rel-links">
          {%- for l in r.links %}
          <a class="rel-btn" href="{{ l.url }}" target="_blank" rel="noopener noreferrer">{{ l.label | safe }}</a>
          {%- endfor %}
        </div>
      </div>
    </article>
    {%- endfor %}
  </div>
</div></section>
{%- elif b.type == "videos" %}
<section id="watch" class="sec"><div class="wrap">
  <div class="movement reveal"><span class="lbl">{{ b.label | safe }}</span><span class="rule"></span></div>
  {%- if b.feature_embed %}
  <div class="feature-film">
    <div class="vframe reveal"><iframe src="{{ b.feature_embed }}" title="{{ b.feature_title }}" loading="lazy" allow="fullscreen; picture-in-picture" allowfullscreen></iframe></div>
    <div class="film-meta reveal"><div class="tag">{{ b.feature_tag | safe }}</div><h3>{{ b.feature_title | safe }}</h3>
      <p>{{ b.feature_text | safe }}</p>
      <a class="btn btn-ghost" href="{{ b.feature_button_url }}" target="_blank" rel="noopener noreferrer">{{ b.feature_button_label | safe }}</a></div>
  </div>
  {%- endif %}
  <div class="vgrid">
    {%- for v in b.videos %}
    {%- include "vcard.njk" %}
    {%- endfor %}
  </div>
  {%- if b.videos2 and b.videos2.length %}
<div class="movement reveal" style="margin-top:64px"><span class="lbl">{{ b.label2 | safe }}</span><span class="rule"></span></div>
  <div class="vgrid">
    {%- for v in b.videos2 %}
    {%- include "vcard.njk" %}
    {%- endfor %}
  </div>
  {%- endif %}
  <script>(function(){document.querySelectorAll(".vplay").forEach(function(b){b.addEventListener("click",function(){var id=b.getAttribute("data-yt"),f=b.closest(".vframe");if(!f)return;f.innerHTML='<iframe src="https://www.youtube.com/embed/'+id+'?rel=0&autoplay=1" title="Christa Dalmazio" allow="autoplay; encrypted-media; picture-in-picture; fullscreen" allowfullscreen></iframe>';});});})();</script>
</div></section>
{%- elif b.type == "affiliations" %}
<section class="sec" style="background:var(--ink-2);border-top:1px solid var(--rule-d)"><div class="wrap">
  <div class="movement center reveal"><span class="lbl">{{ b.label | safe }}</span></div>
  <div class="logowall reveal">
    <div class="lw-side lw-left">
      {%- for l in b.left %}
      {%- if l.url %}<a class="lg{% if l.extra_class %} {{ l.extra_class }}{% endif %}" href="{{ l.url }}" target="_blank" rel="noopener noreferrer"><img src="{{ l.image | replace("XNONEX", "XNONEX") }}" alt="{{ l.alt }}"  loading="lazy" /></a>{% else %}<span class="lg{% if l.extra_class %} {{ l.extra_class }}{% endif %}"><img src="{{ l.image | replace("XNONEX", "XNONEX") }}" alt="{{ l.alt }}"  loading="lazy" /></span>{% endif %}
      {%- endfor %}
    </div>
    <span class="lg lg-feature lw-center"><span class="word word-lg">{{ b.center | safe }}</span></span>
    <div class="lw-side lw-right">
      {%- for l in b.right %}
      {%- if l.url %}<a class="lg{% if l.extra_class %} {{ l.extra_class }}{% endif %}" href="{{ l.url }}" target="_blank" rel="noopener noreferrer"><img src="{{ l.image | replace("XNONEX", "XNONEX") }}" alt="{{ l.alt }}"  loading="lazy" /></a>{% else %}<span class="lg{% if l.extra_class %} {{ l.extra_class }}{% endif %}"><img src="{{ l.image | replace("XNONEX", "XNONEX") }}" alt="{{ l.alt }}"  loading="lazy" /></span>{% endif %}
      {%- endfor %}
    </div>
  </div>
</div></section>
{%- endif %}
{%- endfor %}
