{% raw %}
<script>
const nav=document.getElementById('nav');
addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>40));
const t=document.getElementById('navToggle'),l=document.getElementById('navLinks');
t.addEventListener('click',()=>l.classList.toggle('open'));
l.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>l.classList.remove('open')));
const io=new IntersectionObserver((es)=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}}),{threshold:.08});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
const mf=document.getElementById('mlForm');
if(mf){mf.addEventListener('submit',function(e){e.preventDefault();
  var em=document.getElementById('mlEmail').value;
  mf.style.display='none';
  var d=document.getElementById('mlDone'); if(d) d.style.display='block';
  window.location.href='mailto:christadalmazio@gmail.com?subject='+encodeURIComponent('Mailing list signup')+'&body='+encodeURIComponent('Please add me to your mailing list: '+em);
});}
</script>
