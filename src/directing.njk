.patron-sec{padding:84px 0;background:var(--ink);border-top:1px solid var(--rule-d);text-align:center}
.patron-orn{width:50px;height:50px;opacity:.95;margin:0 auto 22px;display:block;filter:drop-shadow(0 4px 12px rgba(0,0,0,.45))}
.patron-label{font-size:.66rem;letter-spacing:.32em;text-transform:uppercase;color:var(--gilt)}
.patrons{display:grid;grid-template-columns:1fr 1fr;max-width:900px;margin:34px auto 0}
.patron{text-align:center;padding:8px 42px}
.patron-fig{width:190px;aspect-ratio:4/5;margin:0 auto 24px;padding:8px;background:#1c1013;border:2px solid var(--gilt);box-shadow:0 12px 30px rgba(0,0,0,.55)}
.patron-fig img{display:block;width:100%;height:100%;object-fit:cover;border:1px solid var(--gilt-deep)}
.patron+.patron{border-left:1px solid var(--rule-d)}
.patron-name{font-family:'Cormorant Garamond',serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:400;color:var(--parchment);line-height:1.12}
.patron-desc{font-size:.63rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted-2);margin-top:12px}
.patron-q{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(1.12rem,2vw,1.5rem);color:var(--gilt-soft);line-height:1.26;margin:22px auto 0;max-width:26ch;border-top:1px solid var(--rule-d);padding-top:22px;text-wrap:balance}
.patron-q span{display:block;font-style:normal;font-size:.52em;letter-spacing:.13em;text-transform:uppercase;color:var(--muted);margin-top:12px;line-height:1.5;max-width:30ch;margin-left:auto;margin-right:auto;text-wrap:balance}
@media(max-width:680px){.patron-fig{margin-top:6px}}
@media(max-width:680px){.patrons{grid-template-columns:1fr}.patron{padding:0 8px}.patron+.patron{border-left:none;border-top:1px solid var(--rule-d);margin-top:34px;padding-top:34px}}
.perf-stack{display:flex;flex-direction:column;gap:22px}
