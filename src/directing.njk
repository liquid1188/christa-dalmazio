{% raw %}<!DOCTYPE html><html lang="en"><head>
<meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Directing | Christa Dalmazio</title><meta name="description" content="Christa Dalmazio directs sacred music for the Higher Word Orchestra and parishes across New Jersey." />
<meta property="og:title" content="Directing | Christa Dalmazio" /><meta property="og:description" content="Christa Dalmazio directs sacred music for the Higher Word Orchestra and parishes across New Jersey." />
<meta property="og:type" content="website" /><meta property="og:image" content="https://liquid1188.github.io/christa-dalmazio/assets/img/hero.jpg" />
<link rel="icon" type="image/svg+xml" href="assets/img/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="assets/img/favicon-32.png" />
<link rel="apple-touch-icon" href="assets/img/favicon-180.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Mulish:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
<style>
:root{
  --ink:#190d10;--ink-2:#23141a;--ink-3:#321a22;
  --paper:#f1e9d8;--paper-2:#e7dcc4;--paper-ink:#2a141a;--paper-muted:#7c5560;
  --gilt:#c8a866;--gilt-soft:#dcc398;--gilt-deep:#9a7836;
  --parchment:#f3ede1;--muted:#c4a8af;--muted-2:#9c7782;
  --rule-d:rgba(200,168,102,.16);--rule-l:#d7caaf;--maxw:1180px;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{margin:0;background:var(--ink);color:var(--parchment);font-family:'Mulish',system-ui,sans-serif;font-weight:300;line-height:1.68;-webkit-font-smoothing:antialiased;overflow-x:hidden}
h1,h2,h3{font-family:'Cormorant Garamond',Georgia,serif;font-weight:400;margin:0;line-height:1.07}
a{color:inherit;text-decoration:none}
img{max-width:100%;display:block}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 34px}
section{position:relative;z-index:1}
body::before{content:"";position:fixed;inset:0;pointer-events:none;z-index:0;background:radial-gradient(1100px 620px at 80% -10%,rgba(200,168,102,.08),transparent 60%)}
.movement{display:flex;align-items:baseline;gap:16px;margin-bottom:30px}
.movement .lbl{font-weight:600;font-size:.72rem;letter-spacing:.32em;text-transform:uppercase;color:var(--gilt)}
.movement .rule{flex:1;height:1px;background:linear-gradient(90deg,var(--gilt),transparent);align-self:center}
.movement.center{justify-content:center}.movement.center .rule{display:none}
.paper .movement .lbl{color:var(--gilt-deep)}.paper .movement .rule{background:linear-gradient(90deg,var(--gilt-deep),transparent)}
/* NAV */
header.nav{position:fixed;top:0;left:0;right:0;z-index:50;display:flex;align-items:center;justify-content:space-between;padding:20px 34px;transition:background .4s,padding .4s,border-color .4s;border-bottom:1px solid transparent}
header.nav.scrolled{background:rgba(25,13,16,.92);backdrop-filter:blur(12px);padding:13px 34px;border-bottom:1px solid var(--rule-d)}
.brand{display:inline-flex;align-items:center;gap:12px;font-family:'Cormorant Garamond',serif;font-size:1.5rem;letter-spacing:.02em;color:var(--parchment)}.brand-txt{display:flex;flex-direction:column;text-align:center;line-height:1}.brand-name{font-size:1.5rem}.brand-tag{font-family:'Mulish',sans-serif;font-size:.5rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gilt);font-weight:600;margin-top:4px}.brand-rose{width:33px;height:33px;flex:0 0 auto;filter:drop-shadow(0 2px 5px rgba(0,0,0,.5))}header.nav.scrolled .brand-rose{width:29px;height:29px}.brand-txt{display:flex;flex-direction:column;line-height:1.02}.brand-tag{font-family:'Mulish',sans-serif;font-size:.48rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gilt);font-weight:600;margin-top:5px}
.brand b{font-weight:600}
nav.links{display:flex;gap:24px}
nav.links a{font-size:.75rem;letter-spacing:.15em;text-transform:uppercase;font-weight:500;color:var(--muted);position:relative;padding:4px 0;transition:color .25s}
nav.links a::after{content:"";position:absolute;left:0;bottom:0;height:1px;width:0;background:var(--gilt);transition:width .3s}
nav.links a:hover{color:var(--parchment)}nav.links a:hover::after,nav.links a.active::after{width:100%}
nav.links a.active{color:var(--parchment)}
.nav-toggle{display:none;background:none;border:0;color:var(--parchment);font-size:1.5rem;cursor:pointer}
/* BUTTONS */
.btn{font-family:'Mulish',sans-serif;font-weight:600;font-size:.76rem;letter-spacing:.13em;text-transform:uppercase;padding:15px 32px;cursor:pointer;transition:background .2s,color .2s,border-color .2s;display:inline-block;border-radius:0}
.btn-gilt{background:var(--gilt);color:#1a1410}.btn-gilt:hover{background:var(--gilt-soft);transform:translateY(-2px)}
.btn-ghost{border:1px solid rgba(200,168,102,.45);color:var(--gilt-soft)}.btn-ghost:hover{border-color:var(--gilt);background:rgba(200,168,102,.08);transform:translateY(-2px)}
.paper .btn-ghost{border-color:rgba(154,120,54,.5);color:var(--gilt-deep)}.paper .btn-ghost:hover{background:rgba(154,120,54,.08)}
.cta-row{display:flex;gap:15px;flex-wrap:wrap;margin-top:34px}
/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;padding:128px 0 60px;position:relative}
.hero-rose{position:absolute;top:18%;left:50%;transform:translateX(-50%);width:118px;height:118px;z-index:5;filter:drop-shadow(0 8px 22px rgba(0,0,0,.6))}
.hero-grid{display:grid;grid-template-columns:1.04fr .96fr;gap:60px;align-items:center;width:100%}
.hero-kicker{font-weight:600;letter-spacing:.3em;text-transform:uppercase;font-size:.73rem;color:var(--gilt);margin-bottom:24px}
.hero h1{font-size:clamp(3.4rem,8vw,6.6rem);font-weight:300;letter-spacing:-.012em}
.hero h1 .sur{display:block;font-weight:500}
.hero .roles{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(1.25rem,2.3vw,1.7rem);color:var(--gilt-soft);margin:16px 0 22px}
.hero .lede{max-width:33em;color:var(--muted);font-size:1.05rem}
.hero-portrait{position:relative;justify-self:center;display:flex;justify-content:center}
.arch{width:min(420px,80vw);aspect-ratio:1000/1294;border-radius:999px 999px 5px 5px;overflow:hidden;position:relative;z-index:1;border:1px solid rgba(200,168,102,.55);box-shadow:0 30px 70px -30px rgba(0,0,0,.85),0 0 0 9px rgba(200,168,102,.05)}
.arch img{width:100%;height:100%;object-fit:cover;object-position:center 16%}
.arch::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(25,13,16,0) 62%,rgba(25,13,16,.32) 100%)}
.arch-frame{position:absolute;inset:-15px;border:1px solid rgba(200,168,102,.22);border-radius:999px 999px 9px 9px;pointer-events:none;z-index:2}
/* MARQUEE */
.marquee-wrap{border-top:1px solid var(--rule-d);border-bottom:1px solid var(--rule-d);background:var(--ink-2);padding:24px 0;overflow:hidden}
.marquee-label{text-align:center;font-size:.64rem;letter-spacing:.32em;text-transform:uppercase;color:var(--muted-2);margin-bottom:16px}
.marquee{display:flex;align-items:center;width:max-content;animation:scroll 54s linear infinite}
.marquee:hover{animation-play-state:paused}
.marquee .item{display:flex;align-items:center;padding:0 42px;white-space:nowrap;position:relative}
.marquee .item::after{content:"\2726";position:absolute;right:-5px;top:50%;transform:translateY(-50%);font-size:.45rem;color:var(--gilt-deep)}
.marquee img.plogo{height:30px;width:auto;opacity:.66;transition:opacity .35s}
.marquee img.plogo-tall{height:42px}
.marquee .item:hover img.plogo{opacity:1}
@keyframes scroll{to{transform:translateX(-50%)}}
/* PAGE HEADER (subpages) */
.pagehead{padding:170px 0 70px;border-bottom:1px solid var(--rule-d);background:linear-gradient(180deg,var(--ink-2),var(--ink))}
.pagehead .kick{font-weight:600;letter-spacing:.3em;text-transform:uppercase;font-size:.7rem;color:var(--gilt);margin-bottom:18px}
.pagehead h1{font-size:clamp(2.8rem,6vw,4.6rem);font-weight:300}
.pagehead p{color:var(--muted);max-width:54ch;margin-top:20px;font-size:1.08rem}
/* PAPER */
.paper{background:var(--paper);color:var(--paper-ink);background-image:radial-gradient(900px 500px at 12% 0%,rgba(255,255,255,.5),transparent 60%),radial-gradient(800px 600px at 100% 100%,rgba(154,120,54,.06),transparent 55%)}
.paper .muted{color:var(--paper-muted)}
/* HIGHLIGHTS */
.highlights{padding:104px 0}
.hl-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:8px}
.hl-card{position:relative;display:block;overflow:hidden;min-height:300px}
.hl-card img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform .9s ease}
.hl-card:hover img{transform:scale(1.05)}
.hl-card::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(8,18,16,.15) 0%,rgba(8,18,16,.55) 55%,rgba(8,18,16,.9) 100%)}
.hl-card .tx{position:relative;z-index:2;padding:34px;display:flex;flex-direction:column;justify-content:flex-end;height:100%;min-height:300px}
.hl-card h3{font-size:1.9rem;color:var(--parchment)}
.hl-card p{color:var(--muted);font-size:.96rem;margin:8px 0 0}
.hl-card .go{margin-top:16px;font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gilt-soft);font-weight:600}
.hl-card:hover .go{color:var(--gilt)}
/* ENDORSEMENTS */
.endorse{padding:104px 0;background:var(--ink-2);border-top:1px solid var(--rule-d);border-bottom:1px solid var(--rule-d)}
.en-grid{display:grid;grid-template-columns:repeat(2,1fr);column-gap:64px;row-gap:4px;margin-top:20px}
.en-card{padding:30px 2px 4px;border-top:1px solid var(--rule-d)}
.en-q{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.32rem;line-height:1.42;color:var(--muted)}
.en-ph{color:var(--muted-2);font-style:italic}
.en-meta{margin-top:22px;padding-top:18px;border-top:1px solid var(--rule-d)}
.en-name{font-family:'Cormorant Garamond',serif;font-size:1.25rem;color:var(--parchment)}
.en-role{font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted-2);margin-top:5px}
.en-tag{display:inline-block;font-size:.6rem;letter-spacing:.24em;text-transform:uppercase;color:var(--gilt-deep);margin-bottom:14px}
/* BAND */
.band{position:relative;height:60vh;min-height:420px;max-height:600px;overflow:hidden;display:flex;align-items:flex-end}
.band img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 30%}
.band::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(25,13,16,.12) 0%,rgba(25,13,16,.08) 45%,rgba(25,13,16,.8) 100%)}
.band .cap{position:relative;z-index:2;padding:0 0 40px}
.band .q{font-family:'Cormorant Garamond';font-style:italic;font-size:clamp(1.5rem,3vw,2.2rem);color:var(--parchment);max-width:22ch;line-height:1.26}
.band .src{font-size:.68rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gilt-soft);margin-top:14px}
/* GENERIC SECTION */
.sec{padding:108px 0}
.sec-head{font-size:clamp(2.2rem,4.6vw,3.3rem);font-weight:400}
.lead-line{color:var(--muted);font-size:1.08rem;max-width:60ch;margin-top:14px}
.paper .lead-line{color:var(--paper-muted)}
.two{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start}
.bodytext p{font-size:1.06rem;margin:0 0 18px}
.paper .bodytext p{color:var(--paper-muted)}
.bodytext strong{color:var(--paper-ink);font-weight:600}
.paper .bodytext em{font-style:italic;color:var(--gilt-deep)}
.portrait-card img{width:100%;border:1px solid var(--rule-l)}
.portrait-card .cap{font-size:.66rem;letter-spacing:.16em;text-transform:uppercase;color:var(--paper-muted);margin-top:11px;text-align:right}
/* DISS */
.diss{padding:116px 0;border-top:1px solid var(--rule-d);border-bottom:1px solid var(--rule-d);background:linear-gradient(180deg,var(--ink-2),var(--ink))}
.euch{text-align:center;max-width:62ch;margin:0 auto 56px;padding-bottom:50px;border-bottom:1px solid var(--rule-d)}
.euch-rose{width:64px;height:64px;opacity:.92;margin:0 auto 24px;display:block;filter:drop-shadow(0 4px 12px rgba(0,0,0,.45))}
.euch-q{font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:400;font-size:clamp(1.7rem,3.4vw,2.55rem);color:var(--parchment);line-height:1.16;margin:0}
.euch-q span{display:block;font-style:normal;font-size:.34em;letter-spacing:.16em;text-transform:uppercase;color:var(--gilt-soft);margin-top:16px}
.euch-sub{color:var(--muted);font-size:1.02rem;line-height:1.7;margin:24px auto 0;max-width:54ch}
.diss-card{max-width:860px;margin:0 auto;text-align:center}
.diss .deg{font-size:.7rem;letter-spacing:.26em;text-transform:uppercase;color:var(--gilt);margin-bottom:18px}
.diss h2{font-size:clamp(1.9rem,4vw,2.9rem);font-weight:400;font-style:italic;line-height:1.2}
.diss .sub{color:var(--muted);margin-top:22px;font-size:1.04rem;max-width:60ch;margin-left:auto;margin-right:auto}
.diss .meta{display:flex;justify-content:center;flex-wrap:wrap;gap:8px 32px;margin-top:30px;font-size:.72rem;letter-spacing:.07em;text-transform:uppercase;color:var(--muted-2)}
.diss .meta b{color:var(--gilt-soft);font-weight:600}
/* PROGRAM (roles) */
.program{width:100%;border-collapse:collapse}
.program tr{border-bottom:1px solid var(--rule-l)}
.program td{padding:13px 6px;vertical-align:baseline}
.program .role{font-family:'Cormorant Garamond';font-size:1.34rem;color:var(--paper-ink);white-space:nowrap}
.program .work{font-style:italic;color:var(--paper-muted);font-size:.96rem}
.program .co{text-align:right;font-size:.69rem;letter-spacing:.07em;text-transform:uppercase;color:var(--paper-muted);white-space:nowrap}
.scenes{margin-top:22px;color:var(--paper-muted);font-size:.93rem}
.scenes b{display:block;color:var(--gilt-deep);font-weight:600;font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;margin-bottom:8px}
.figcap img{width:100%;border:1px solid var(--rule-l)}
.figcap figcaption{font-size:.7rem;letter-spacing:.04em;color:var(--paper-muted);margin-top:11px;font-style:italic;text-align:right}
.listcols{display:grid;grid-template-columns:1fr 1fr;gap:54px;margin-top:50px;padding-top:42px;border-top:1px solid var(--rule-l)}
.listcols h3{font-size:1.4rem;color:var(--paper-ink);margin-bottom:16px;font-weight:500}
.cs-entry{padding:13px 0;border-top:1px solid var(--rule-l)}.cs-entry:first-of-type{border-top:0}
.cs-entry .t{font-family:'Cormorant Garamond';font-size:1.14rem;color:var(--paper-ink)}
.cs-entry .d{color:var(--paper-muted);font-size:.9rem;margin-top:2px}
.cs-entry .tag{font-size:.64rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gilt-deep);font-weight:600}
/* WATCH */
.vframe{position:relative;width:100%;aspect-ratio:16/9;border:1px solid rgba(200,168,102,.3);overflow:hidden;background:#000}
.vframe iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
.feature-film{display:grid;grid-template-columns:1.5fr 1fr;gap:46px;align-items:center;margin-bottom:50px}
.film-meta .tag{font-size:.66rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gilt);font-weight:600}
.film-meta h3{font-size:1.9rem;margin:10px 0 12px}
.film-meta p{color:var(--muted);font-size:1rem;margin-bottom:22px}
.vgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:26px}
.vcard .vt{font-family:'Cormorant Garamond';font-style:italic;font-size:1.2rem;margin-top:14px}
.vcard .vc{color:var(--muted-2);font-size:.8rem;margin-top:3px}
/* COLLAB */
.logowall{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;column-gap:56px;margin-top:6px}
.lw-side{display:flex;align-items:center;gap:48px}
.lw-left{justify-content:flex-end}
.lw-right{justify-content:flex-start}
.lw-center{justify-self:center}
.logowall .lg{height:56px;display:flex;align-items:center;opacity:.66;transition:opacity .3s,transform .3s}
.logowall .lg:hover{opacity:1;transform:translateY(-2px)}
.logowall img{height:100%;width:auto;filter:saturate(0)}
.logowall .lg-a2b{height:78px}
.logowall .word{font-family:'Cormorant Garamond';font-size:1.7rem;letter-spacing:.02em;line-height:1;text-align:center;color:var(--parchment)}
.logowall .word-lg{font-size:2.25rem}
.logowall .lg-feature{height:auto;opacity:.92}
.logowall .word small{display:block;font-family:'Mulish';font-size:.55rem;letter-spacing:.22em;text-transform:uppercase;color:var(--muted-2);margin-top:6px}
@media (max-width:760px){.logowall{display:flex;flex-wrap:wrap;justify-content:center;gap:28px 40px}.lw-side{gap:28px 40px;flex-wrap:wrap;justify-content:center}.band img{object-position:73% 30%}.band{min-height:380px}}
.collab-note{text-align:center;color:var(--muted);max-width:62ch;margin:34px auto 0;font-size:.96rem}
.collab-note em{color:var(--gilt-soft);font-style:normal}
/* POSTS */
.post{display:flex;justify-content:space-between;gap:20px;padding:16px 0;border-top:1px solid var(--rule-l)}
.post:first-of-type{border-top:0}
.post .p-role{font-family:'Cormorant Garamond';font-size:1.24rem;color:var(--paper-ink)}
.post .p-place{color:var(--paper-muted);font-size:.88rem;margin-top:3px}
.post .p-loc{font-size:.69rem;letter-spacing:.1em;text-transform:uppercase;color:var(--paper-muted);white-space:nowrap;text-align:right;padding-top:6px}
.studio{background:var(--paper-2);border:1px solid var(--rule-l);padding:38px;border-radius:0}
.studio h3{font-size:1.7rem;margin-bottom:12px;color:var(--paper-ink)}
.studio p{color:var(--paper-muted);font-size:.96rem}
.instruments{display:flex;flex-wrap:wrap;gap:9px;margin:22px 0 26px}
.pill{font-size:.71rem;letter-spacing:.1em;text-transform:uppercase;color:var(--gilt-deep);border:1px solid rgba(154,120,54,.4);padding:8px 14px;border-radius:0}
.offer{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:42px}
.offer .o{border:1px solid var(--rule-l);padding:26px;border-radius:0}
.offer .o h4{font-family:'Cormorant Garamond';font-size:1.4rem;color:var(--paper-ink);margin:0 0 8px;font-weight:500}
.offer .o p{color:var(--paper-muted);font-size:.92rem;margin:0}
/* RECORDINGS */
.recordings .rec-intro{max-width:62ch;color:var(--muted);font-size:1.02rem;line-height:1.7;margin:0 0 34px}
.recordings .rec-intro a{color:var(--gilt-soft);border-bottom:1px solid var(--rule-d);transition:color .25s}
.recordings .rec-intro a:hover{color:var(--gilt)}
.rel-list{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.rel-card{display:flex;gap:20px;align-items:flex-start;background:rgba(255,255,255,.03);border:1px solid var(--rule-d);border-radius:0;padding:22px;transition:border-color .3s}
.rel-card:hover{border-color:var(--gilt-deep)}
.rel-cover{width:128px;height:128px;object-fit:cover;border-radius:0;flex-shrink:0;border:1px solid var(--rule-d)}
.rel-body{flex:1;min-width:0}
.rel-tag{font-size:.64rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gilt);margin-bottom:7px}
.rel-title{font-family:'Cormorant Garamond';font-size:1.75rem;color:var(--parchment);line-height:1;margin:0 0 8px}
.rel-credit{color:var(--muted);font-size:.9rem;line-height:1.4}
.rel-role{color:var(--parchment);font-size:.9rem;margin-top:2px;opacity:.85}
.rel-note{color:var(--muted-2);font-size:.82rem;margin-top:9px;font-style:italic;line-height:1.5}
.rel-links{display:flex;gap:8px;margin-top:15px;flex-wrap:wrap}
.rel-btn{font-size:.72rem;letter-spacing:.07em;text-transform:uppercase;color:var(--parchment);border:1px solid var(--rule-d);padding:7px 14px;border-radius:0;transition:border-color .2s,color .2s,background .2s}
.rel-btn:hover{border-color:var(--gilt);color:var(--gilt);background:rgba(200,168,102,.06)}
@media (max-width:820px){.rel-list{grid-template-columns:1fr}}
@media (max-width:480px){.rel-card{flex-direction:column}.rel-cover{width:100%;height:210px}}
/* GALLERY (masonry, no cropping) */
.gallery{padding:60px 0 96px}
.gal{column-count:3;column-gap:18px}
.gal figure{margin:0 0 18px;break-inside:avoid;position:relative;overflow:hidden;border:1px solid var(--rule-d);border-radius:0}
.gal img{width:100%;height:auto;display:block;transition:transform .8s ease}
.gal figure:hover img{transform:scale(1.035)}
.gal figcaption{position:absolute;left:0;right:0;bottom:0;padding:30px 16px 12px;font-size:.72rem;letter-spacing:.04em;color:#f3ede1;background:linear-gradient(180deg,transparent,rgba(8,18,16,.82));opacity:0;transition:opacity .35s}
.gal figure:hover figcaption{opacity:1}
@media (max-width:900px){.gal{column-count:2}}
@media (max-width:560px){.gal{column-count:1}}
/* PRESS LIST */
.press-list{margin-top:48px;padding-top:42px;border-top:1px solid var(--rule-l)}
.pl-head{font-size:1.4rem;color:var(--paper-ink);margin-bottom:20px;font-weight:500}
.pl-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.pl-item{padding:18px 0;border-top:1px solid var(--rule-l)}
.pl-t{font-family:'Cormorant Garamond';font-size:1.18rem;color:var(--paper-ink)}
.pl-d{color:var(--paper-muted);font-size:.86rem;margin-top:3px}
/* MAILING */
.mailing{padding:64px 0;background:var(--ink);border-top:1px solid var(--rule-d)}
.ml-inner{display:flex;align-items:center;justify-content:space-between;gap:34px;flex-wrap:wrap}
.ml-text h3{font-size:1.9rem;color:var(--parchment)}
.ml-text p{color:var(--muted);font-size:.98rem;margin:6px 0 0}
.ml-form{display:flex;gap:12px;flex:1;min-width:300px;max-width:520px}
.ml-form input{flex:1;min-width:0;background:rgba(255,255,255,.04);border:1px solid var(--rule-d);color:var(--parchment);padding:14px 18px;font-family:'Mulish';font-size:.95rem;border-radius:0;outline:none;transition:border-color .25s}
.ml-form input:focus{border-color:var(--gilt)}
.ml-form input::placeholder{color:var(--muted-2)}
.ml-form .btn{white-space:nowrap}
.ml-done{display:none;color:var(--gilt-soft);font-family:'Cormorant Garamond';font-style:italic;font-size:1.2rem}
/* CONTACT */
.contact{padding:70px 0;background:var(--ink-2);border-top:1px solid var(--rule-d)}
.contact .inner{text-align:center;max-width:680px;margin:0 auto}
.contact h2{font-size:clamp(2.3rem,5.2vw,3.7rem);font-weight:300;margin-bottom:16px}
.contact h2 em{font-style:italic;color:var(--gilt-soft)}
.contact p{color:var(--muted);font-size:1.07rem;margin-bottom:30px}
.contact .cta-row{justify-content:center}
/* FOOTER */
footer{padding:60px 0 38px;border-top:1px solid var(--rule-d);text-align:center}.f-lockup{display:flex;flex-direction:column;align-items:center;gap:9px;margin-bottom:30px}.f-lockup img{width:48px;height:48px}.f-name{font-family:'Cormorant Garamond',serif;font-size:1.65rem;color:var(--parchment);letter-spacing:.02em;line-height:1}.f-tag{font-size:.63rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gilt)}.f-menu{display:flex;flex-wrap:wrap;justify-content:center;gap:9px 26px;margin-bottom:22px}.f-menu a{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);transition:color .25s}.f-menu a:hover{color:var(--gilt)}.f-social{display:flex;justify-content:center;gap:22px;flex-wrap:wrap}.f-social a{font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted-2);transition:color .25s}.f-social a:hover{color:var(--gilt)}.f-meta{font-size:.68rem;letter-spacing:.05em;color:var(--muted-2);padding-top:22px;margin-top:26px;border-top:1px solid var(--rule-d)}
.reveal{opacity:0;transform:translateY(24px);transition:opacity .9s,transform .9s}
.reveal.in{opacity:1;transform:none}
@media (max-width:900px){
  .hero-grid,.two,.feature-film,.vgrid,.hl-grid,.en-grid,.listcols,.offer{grid-template-columns:1fr}
  .hero{min-height:auto;padding-top:156px}.hero-portrait{order:-1;margin-bottom:14px}
  .hero-rose{top:60px;width:84px;height:84px}
  nav.links{position:fixed;inset:0 0 0 auto;width:76%;max-width:320px;flex-direction:column;justify-content:center;gap:26px;background:rgba(25,13,16,.97);backdrop-filter:blur(14px);padding:40px;transform:translateX(100%);transition:transform .4s;border-left:1px solid var(--rule-d)}
  nav.links.open{transform:none}nav.links a{font-size:1rem}
  .nav-toggle{display:block;z-index:60}
}
@media (max-width:520px){.wrap{padding:0 22px}header.nav{padding:16px 22px}.program .co{display:none}.ml-inner{flex-direction:column;align-items:stretch;text-align:center;gap:20px}.ml-form{flex-direction:column;min-width:0;max-width:none;width:100%}.ml-form .btn{width:100%}}
@media (prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}.reveal{opacity:1;transform:none}html{scroll-behavior:auto}.marquee{animation:none;flex-wrap:wrap;width:auto;justify-content:center}}


/* shared block styles (added for CMS section builder) */
.instr-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin:20px 0 26px}
